{
  "name": "wgblas",
  "version": "1.0.0",
  "description": "BLAS on WebGPU",
  "type": "module",
  "main": "index.mjs",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "types": "./index.d.ts"
    },
    "./sscal": {
      "import": "./src/sscal/sscal.mjs",
      "types": "./src/sscal/sscal.d.ts"
    },
    "./sswap": {
      "import": "./src/sswap/sswap.mjs",
      "types": "./src/sswap/sswap.d.ts"
    },
    "./saxpy": {
      "import": "./src/saxpy/saxpy.mjs",
      "types": "./src/saxpy/saxpy.d.ts"
    },
    "./scopy": {
      "import": "./src/scopy/scopy.mjs",
      "types": "./src/scopy/scopy.d.ts"
    },
    "./sdot": {
      "import": "./src/sdot/sdot.mjs",
      "types": "./src/sdot/sdot.d.ts"
    },
    "./sasum": {
      "import": "./src/sasum/sasum.mjs",
      "types": "./src/sasum/sasum.d.ts"
    },
    "./snrm2": {
      "import": "./src/snrm2/snrm2.mjs",
      "types": "./src/snrm2/snrm2.d.ts"
    },
    "./util/random": "./src/util/random.mjs",
    "./classes/GpuVector": {
      "import": "./src/classes/GpuVector.mjs",
      "types": "./src/classes/GpuVector.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manit2004/wgblas.git"
  },
  "keywords": [
    "BLAS",
    "WebGPU"
  ],
  "author": "Manit Roy",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/manit2004/wgblas/issues"
  },
  "homepage": "https://github.com/manit2004/wgblas#readme",
  "dependencies": {
    "webgpu": "^0.4.0"
  },
  "devDependencies": {
    "vite": "^8.0.16"
  }
}
